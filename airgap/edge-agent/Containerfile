# Offline-buildable container for the Rust edge-agent.
# Requires `vendor/` and `.cargo/config.toml` to be present (see ../docs/RUST-OFFLINE-BUILD.md).

FROM rust:alpine AS builder
RUN apk add --no-cache musl-dev
WORKDIR /src
COPY Cargo.toml Cargo.lock ./
COPY .cargo/ ./.cargo/
COPY vendor/ ./vendor/
COPY src/ ./src/
RUN cargo build --release --offline

FROM alpine:3.20
COPY --from=builder /src/target/release/edge-agent /edge-agent
USER 65534:65534
ENTRYPOINT ["/edge-agent"]
