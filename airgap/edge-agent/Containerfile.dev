# Online dev build of the Rust edge-agent. Runs from a host that can reach
# crates.io (e.g. the libvirt host via Tailscale). Skips the vendor/ dance.
# For airgap bundle builds, see Containerfile (offline, vendor-based).
FROM rust:alpine AS builder
RUN apk add --no-cache musl-dev
WORKDIR /src
COPY Cargo.toml Cargo.lock* ./
COPY src/ ./src/
RUN cargo fetch && cargo build --release

FROM alpine:3.20
COPY --from=builder /src/target/release/edge-agent /edge-agent
USER 65534:65534
ENTRYPOINT ["/edge-agent"]
